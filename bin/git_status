#!/usr/bin/env zsh

# is the current folder part of a git repo
function is_git() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

function git_branch() {
  print -rn -- $(git rev-parse --abbrev-ref HEAD)
}

function git_ahead_and_behind() {
  nums=$(git rev-list --left-right --count HEAD...origin/master)
  ahead=$(echo $nums | cut -f 1)
  behind=$(echo $nums | cut -f 2)
  if [[ $ahead > 0 ]]; then
    print -rn -- "пҳҫ$ahead"
  fi
  if [[ $behind > 0 ]]; then
    print -rn -- "пҳ»$behind"
  fi
  if [[ $ahead > 0 ]] || [[ $behind > 0 ]]; then
    print -rn -- " "
  fi
}

function git_clean_status() {
  gstatus=$(git status --porcelain | sed "s/^ //" | cut -d' ' -f 1)
  echo $gstatus | egrep "[MD]" > /dev/null; dirty=$?
  echo $gstatus | grep "??" > /dev/null; unstaged=$?
  if [[ $dirty == 0 ]] && [[ $unstaged == 0 ]]; then
    print -rn -- "пҒҷ пҒ•"
  elif [[ $dirty == 0 ]]; then
    print -rn -- "пҒ•"
  elif [[ $unstaged == 0 ]]; then
    print -rn -- "пҒҷ"
  else
    print -rn -- "пҒҳ"
  fi
}

if is_git; then
  echo "$(git_branch) $(git_ahead_and_behind)$(git_clean_status)"
fi
