{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "pink": "#F5C2E7",
    "lavender": "#B4BEFE",
    "blue": "#89B4FA",
    "lime": "#d2ff5e",
    "navy": "#193549",
    "yellow": "#fed766",
    "red": "#BF616A",
    "orange": "#ff9248",
    "reddish-orange": "#f26d50",
    "teal": "#89d1dc",
    "yellowish-orange": "#f17c37",
    "g-blue": "#4285F4",
    "g-red": "#DB4437",
    "g-yellow": "#F4B400",
    "g-green": "#0F9D58"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:blue",
          "properties": {
            "folder_icon": "··",
            "home_icon": "~",
            "style": "agnoster_short",
            "mapped_locations": {
              "/Users/tingzhou/Documents/GitHub": "",
              "/Users/tingzhou/.dotfiles": ""
            }
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "type": "python",
          "background": "p:yellow",
          "foreground": "p:navy",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ if .Full }}{{ .Full }} {{ end }}{{ end }}"
        },
        {
          "background": "p:lime",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:orange{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:reddish-orange{{ end }}",
            "{{ if gt .Ahead 0 }}p:teal{{ end }}",
            "{{ if gt .Behind 0 }}p:yellowish-orange{{ end }}"
          ],
          "foreground": "p:navy",
          "properties": {
            "branch_icon": " ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:pink",
          "type": "session",
          "template": "{{ if .SSHSession }} {{ end }}{{ .UserName }}@{{ .HostName }} "
        },
        {
          "type": "battery",
          "style": "plain",
          "foreground": "white",
          "background": "red",
          "foreground_templates": [
            "{{if eq \"Charging\" .State.String}}p:navy{{end}}",
            "{{if gt .Percentage 0.8}}p:navy{{end}}",
            "{{if gt .Percentage 0.5}}white{{end}}",
            "{{if gt .Percentage 0.3}}p:navy{{end}}",
            "{{if gt .Percentage 0.01}}white{{end}}"
          ],
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}p:lime{{end}}",
            "{{if gt .Percentage 0.8}}p:g-green{{end}}",
            "{{if gt .Percentage 0.5}}p:g-blue{{end}}",
            "{{if gt .Percentage 0.3}}p:g-yellow{{end}}",
            "{{if gt .Percentage 0.01}}p:g-red{{end}}"
          ],
          "templates_logic": "first_match",
          "templates": [
            " {{ if eq \"Charging\" .State.String }}󱟦 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.9 }}󰂂 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.8 }}󰂁 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.7 }}󰂀 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.6 }}󰁿 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.5 }}󰁾 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.4 }}󰁽 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.3 }}󰁼 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.2 }}󰁻 {{ .Percentage }} {{end}}",
            " {{ if gt .Percentage 0.1 }}󰁺 {{ .Percentage }} {{end}}"
          ]
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "alias": "Closer",
          "foreground": "green",
          "template": "\n➜",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "p:yellow",
          "foreground": "p:navy",
          "type": "executiontime",
          "template": "  {{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " {{ .CurrentDate | date .Format }}",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ],
      "type": "rprompt"
    }
  ],
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "template": "• "
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "template": "{{ .Segments.Time.CurrentDate | date .Segments.Time.Format }} {{ if gt .Code 0 }}%{$(tput setaf 1)%}{{ .Code }}  {{ else }}%{$(tput setaf 2)%} {{ end }}"
  },
  "final_space": true,
  "version": 2
}
