#!/bin/zsh

GREEN='\033[0;32m'
NC='\033[0m'

# Check if required commands exist
for cmd in mods gum; do
    if ! command -v $cmd &> /dev/null; then
        echo "Error: Required command '$cmd' not found"
        exit 1
    fi
done

# Parse logging flag; use default logging dir and timestamped name if not
# specified.
zparseopts -D -E - l:=log_file -log:=log_file
LOG_FILE=${log_file[2]:-"$HOME/.local/share/mods/$(date +%Y%m%d_%H%M%S).log"}
mkdir -p "${LOG_FILE:h}"

# Generate a random session title
generate_title() {
    local words=($(cat /usr/share/dict/words 2>/dev/null | grep -E '^[a-z]{4,8}$' | shuf -n 2))
    if [ ${#words[@]} -eq 0 ]; then
        # Fallback if dictionary is not available
        words=($(echo "chat$(date +%s)" | sha256sum | cut -c1-12))
    fi
    echo "${words[1]}-${words[2]}"
}

# Initialize session
SESSION_TITLE=$(generate_title)
echo -e "Starting new chat session: ${GREEN}$SESSION_TITLE${NC}\n"

# Main chat loop
while true; do
    # Use gum to get multiline input with a prompt
    USER_INPUT=$(gum write --placeholder "Enter your message (Ctrl+D to send, Ctrl+C to exit)")
    
    # Check if input is empty (user pressed Ctrl+D without input)
    if [ -z "$USER_INPUT" ]; then
      exit 0
    fi
    
    # Print response with formatting
    # Show the user input with a marker
    echo -e "${GREEN}You:${NC} ${USER_INPUT}"
    
    # Send to mods, capturing only stdout
    if [ -z "$FIRST_MESSAGE" ]; then
        # First message in session
        RESPONSE=$(mods --title "$SESSION_TITLE" $@ "$USER_INPUT" 2>/dev/null)
        echo -e "${GREEN}LLM:${NC} $RESPONSE"
        FIRST_MESSAGE=1
    else
        # Continuing session
        RESPONSE=$(mods --continue "$SESSION_TITLE" $@ "$USER_INPUT" 2>/dev/null)
        echo -e "${GREEN}LLM:${NC} $RESPONSE"
    fi
    
    # Log to file if enabled; no coloring
    if [[ -n "$LOG_FILE" ]]; then
        echo "[$(date -Iseconds)] User: $USER_INPUT" >> "$LOG_FILE"
        echo "[$(date -Iseconds)] LLM: $RESPONSE" >> "$LOG_FILE"
    fi
    
    # Print prompt for next input
    echo ""
done
