#!/usr/bin/env zsh

# get extended path
source $HOME/.zsh/base.zsh
set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

# PROMPT_MSG="write a succinct git commit command with -a, with semantic commit message title (<70 chars) and description under 200 chars"
PROMPT_MSG='summarize the commit with a title that follows the semantic commit message format, <70 chars, \
 and a description under 200 chars, format as raw json without formatting with field names "title" and "desc".'

# temporarily add untracked files as "intended to commit"
git add -N .
WILL_DO=$(git diff HEAD | mods -f ${PROMPT_MSG} 2>/dev/null)
TITLE=$(echo ${WILL_DO} | jq -r .title)
DESC=$(echo ${WILL_DO} | jq -r .desc)

if [[ $* == *"-y"* ]]; then
    # Flag is present
    git commit -am ${TITLE} -m ${DESC}
    exit $?
fi

# gum confirm "Use generated title and description?" && eval ${WILL_DO}
TITLE=$(gum input --prompt "Title: " --value "${TITLE}")
echo -e "Description:"
DESC=$(gum write --prompt "Description: " --value "${DESC}")

cmd="git commit -am \"${TITLE}\" -m \"${DESC}\""
gum confirm ${cmd} && git commit -am ${TITLE} -m ${DESC}
