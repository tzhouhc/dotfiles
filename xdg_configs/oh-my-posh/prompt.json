{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "pink": "#F5C2E7",
    "lavender": "#B4BEFE",
    "blue": "#89B4FA",
    "lime": "#d2ff5e",
    "navy": "#193549",
    "yellow": "#fed766",
    "red": "#BF616A",
    "orange": "#ff9248",
    "reddish-orange": "#f26d50",
    "teal": "#89d1dc",
    "yellowish-orange": "#f17c37"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:blue",
          "properties": {
            "folder_icon": "┬Ę’ü╝┬Ę",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "type": "python",
          "background": "p:yellow",
          "foreground": "p:navy",
          "template": " ŅłĄ {{ if .Error }}{{ .Error }}{{ else }}{{ if .Full }}{{ .Full }} {{ end }}{{ end }}"
        },
        {
          "background": "p:lime",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:orange{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:reddish-orange{{ end }}",
            "{{ if gt .Ahead 0 }}p:teal{{ end }}",
            "{{ if gt .Behind 0 }}p:yellowish-orange{{ end }}"
          ],
          "foreground": "p:navy",
          "properties": {
            "branch_icon": "’Éś ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} ’üä {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} ’üå {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} ŅŁŗ {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:pink",
          "type": "session",
          "template": "{{ if .SSHSession }}¾▒ś¢ {{ end }}{{ .UserName }}@{{ .HostName }}"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "alias": "Closer",
          "foreground": "green",
          "template": "\nŌ×£",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "p:yellow",
          "foreground": "p:navy",
          "type": "executiontime",
          "template": " ¾▒Ä½ {{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " {{ .CurrentDate | date .Format }}",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ],
      "type": "rprompt"
    }
  ],
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "template": "ŌĆó "
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "template": "{{ .Segments.Time.CurrentDate | date .Segments.Time.Format }} {{ if gt .Code 0 }}%{$(tput setaf 1)%}{{ .Code }} ’æż {{ else }}%{$(tput setaf 2)%}’æż {{ end }}"
  },
  "final_space": true,
  "version": 2
}
