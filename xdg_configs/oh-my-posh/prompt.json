{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "palette": {
    "pink": "#F5C2E7",
    "lavender": "#B4BEFE",
    "blue": "#89B4FA",
    "lime": "#d2ff5e",
    "navy": "#193549",
    "yellow": "#fed766",
    "red": "#BF616A"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "p:blue",
          "properties": {
            "folder_icon": "··",
            "home_icon": "~",
            "style": "agnoster_short"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "background": "p:lime",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#ff9248{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#f26d50{{ end }}",
            "{{ if gt .Ahead 0 }}#89d1dc{{ end }}",
            "{{ if gt .Behind 0 }}#f17c37{{ end }}"
          ],
          "foreground": "p:navy",
          "properties": {
            "branch_icon": " ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "p:pink",
          "type": "session",
          "template": "{{ if .SSHSession }}󱘖 {{ end }}{{ .UserName }}@{{ .HostName }}"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "alias": "Closer",
          "foreground": "green",
          "template": "\n➜",
          "type": "text"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "p:yellow",
          "foreground": "p:navy",
          "type": "executiontime",
          "template": " 󱎫 {{ .FormattedMs }} ",
          "properties": {
            "threshold": 500,
            "style": "austin"
          }
        },
        {
          "type": "time",
          "style": "plain",
          "foreground": "p:yellow",
          "template": " {{ .CurrentDate | date .Format }}",
          "properties": {
            "time_format": "15:04:05"
          }
        }
      ],
      "type": "rprompt"
    }
  ],
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "#3B4252",
    "template": "• "
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "darkGray",
    "foreground_templates": ["{{ if gt .Code 0 }}p:red{{ end }}"],
    "template": "{{ .Segments.Time.CurrentDate | date .Segments.Time.Format }} {{ if gt .Code 0 }}{{ .Code }} {{ end }} "
  },
  "final_space": true,
  "version": 2
}
