#!/usr/bin/env zsh

# is the current folder part of a git repo
function is_git() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1
}

# is the current git repo dirty
function git_dirty() {
  git status -s | grep 'M' > /dev/null
}

function git_unstaged() {
  git status -s | grep '??' > /dev/null
}

function git_branch() {
  print -rn -- $(git rev-parse --abbrev-ref HEAD)
}

function git_in_master() {
  git_branch | grep master > /dev/null
}

function git_branch_mark() {
  if git_in_master; then
    print -rn -- " "
  else
    print -rn -- " "
  fi
}

function git_ahead_and_behind() {
  nums=$(git rev-list --left-right --count $(git_branch)...origin/master)
  ahead=$(echo $nums | cut -f 1)
  behind=$(echo $nums | cut -f 2)
  if [[ $ahead > 0 ]]; then
    print -rn -- "$ahead"
  fi
  if [[ $behind > 0 ]]; then
    print -rn -- "$behind"
  fi
  if [[ $ahead > 0 ]] || [[ $behind > 0 ]]; then
    print -rn -- " "
  fi
}

function git_clean_status() {
  dirty=git_dirty
  unstaged=git_unstaged
  if $dirty && $unstaged; then
    print -rn -- " "
  elif $dirty; then
    print -rn -- ""
  elif $unstaged; then
    print -rn -- ""
  else
    print -rn -- ""
  fi
}

if is_git; then
  echo "$(git_branch) $(git_ahead_and_behind)$(git_clean_status)"
fi
